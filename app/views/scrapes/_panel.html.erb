<%# Live-updating region of the show page. Replaced in place via Turbo Stream
    each time the job changes (see ScrapeJob#broadcast_panel). %>
<div id="<%= scrape_job.panel_dom_id %>">
  <p class="status-line">
    <span class="label">status</span>
    <span class="state state--<%= scrape_job.status %>"><%= scrape_job.status %></span>
  </p>

  <% if scrape_job.done? && scrape_job.result %>
    <% if scrape_job.truncated? %>
      <p class="warning">
        Heads up: the page was long and got truncated before extraction, so
        results may be incomplete.
      </p>
    <% end %>
    <%# Fully-qualified: this partial also renders from broadcasts (no controller
        context), where a bare "result" would look under application/. %>
    <%= render "scrapes/result", scrape_job: scrape_job %>
  <% elsif scrape_job.failed? %>
    <p class="error">Failed: <%= scrape_job.error_message %></p>
  <% else %>
    <p>Working on it&hellip; this page updates automatically.</p>
  <% end %>
</div>
