<%# Renders an extraction result table. Columns come from ScrapeJob#result_columns
    (the union of all item keys) and each cell is looked up by key, so
    heterogeneous / reordered item keys never shift values into the wrong
    column (B3). %>
<% result = scrape_job.result %>

<% if result["notes"].present? %>
  <p class="notes"><em><%= result["notes"] %></em></p>
<% end %>

<% if scrape_job.result_items.any? %>
  <p><%= link_to "Download CSV", export_scrape_path(scrape_job, format: :csv) %></p>
  <% columns = scrape_job.result_columns %>
  <table>
    <thead>
      <tr>
        <% columns.each do |key| %>
          <th><%= key %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% scrape_job.result_items.each do |item| %>
        <tr>
          <% columns.each do |key| %>
            <td><%= item[key] %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No items found.</p>
<% end %>

<details>
  <summary>Raw JSON</summary>
  <pre><%= JSON.pretty_generate(result) %></pre>
</details>
