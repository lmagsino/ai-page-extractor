<%# Renders an extraction result. Columns are the UNION of all item keys and
    each cell is looked up by key (B3), so heterogeneous / reordered item keys
    never shift values into the wrong column. %>
<% items = result["items"] || [] %>

<% if result["notes"].present? %>
  <p class="notes"><em><%= result["notes"] %></em></p>
<% end %>

<% if items.any? %>
  <% columns = items.flat_map(&:keys).uniq %>
  <table>
    <thead>
      <tr>
        <% columns.each do |key| %>
          <th><%= key %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% items.each do |item| %>
        <tr>
          <% columns.each do |key| %>
            <td><%= item[key] %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No items found.</p>
<% end %>

<details>
  <summary>Raw JSON</summary>
  <pre><%= JSON.pretty_generate(result) %></pre>
</details>
